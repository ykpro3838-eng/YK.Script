<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dimitri Krokos – Psychologue</title>
  <meta name="description" content="Psychologue & neuropsychologue – Dimitri Krokos. Prise de rendez-vous en ligne, site moderne et professionnel." />

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg-main: linear-gradient(135deg, #0f172a, #0b3c5d);
      --bg-card: rgba(255,255,255,0.06);
      --accent: #38bdf8;
      --accent-soft: #7dd3fc;
      --text-main: #e5e7eb;
      --text-soft: #94a3b8;
      --border-soft: rgba(255,255,255,0.15);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: 'Inter', sans-serif;
      background: var(--bg-main);
      color: var(--text-main);
      overflow-x: hidden;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 40px;
      backdrop-filter: blur(12px);
      background: rgba(15, 23, 42, 0.85);
      border-bottom: 1px solid var(--border-soft);
    }

    header strong { font-size: 20px; letter-spacing: 0.5px; }

    nav a {
      margin-left: 24px;
      color: var(--text-main);
      text-decoration: none;
      font-weight: 500;
      position: relative;
    }

    nav a::after {
      content: "";
      position: absolute;
      bottom: -6px;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--accent);
      transition: width 0.3s;
    }

    nav a:hover::after { width: 100%; }

    .hero {
      min-height: 90vh;
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 60px;
      align-items: center;
      padding: 100px 60px;
    }

    .hero h1 { font-size: 52px; line-height: 1.1; margin-bottom: 20px; }
    .hero p { font-size: 18px; color: var(--text-soft); max-width: 520px; }

    .btn {
      margin-top: 30px;
      display: inline-block;
      padding: 16px 34px;
      background: linear-gradient(135deg, var(--accent), var(--accent-soft));
      color: #0f172a;
      border-radius: 14px;
      font-weight: 600;
      text-decoration: none;
      transition: transform 0.25s, box-shadow 0.25s;
      box-shadow: 0 10px 30px rgba(56,189,248,0.4);
    }

    .btn:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(56,189,248,0.6);
    }

    .hero img {
      width: 100%;
      border-radius: 26px;
      box-shadow: 0 30px 80px rgba(0,0,0,0.5);
    }

    section { padding: 100px 60px; }
    h2 { font-size: 36px; margin-bottom: 20px; }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 30px;
      margin-top: 40px;
    }

    .card {
      background: var(--bg-card);
      border: 1px solid var(--border-soft);
      padding: 40px;
      border-radius: 26px;
      backdrop-filter: blur(16px);
      transition: transform 0.35s, box-shadow 0.35s;
    }

    .card:hover {
      transform: translateY(-10px) scale(1.02);
      box-shadow: 0 30px 80px rgba(0,0,0,0.6);
    }

    form { max-width: 520px; display: grid; gap: 18px; margin-top: 40px; }
    input, textarea, select {
      background: rgba(255,255,255,0.08);
      border: 1px solid var(--border-soft);
      padding: 16px;
      border-radius: 14px;
      color: var(--text-main);
      font-family: inherit;
    }

    input::placeholder, textarea::placeholder { color: var(--text-soft); }

    iframe { width: 100%; height: 320px; border-radius: 26px; border: 0; margin-top: 40px; }

    footer {
      padding: 50px;
      text-align: center;
      color: var(--text-soft);
      border-top: 1px solid var(--border-soft);
      background: rgba(15,23,42,0.8);
    }

    @media(max-width: 900px) {
      .hero { grid-template-columns: 1fr; padding: 80px 30px; text-align: center; }
      section { padding: 80px 30px; }
    }

    @keyframes pop {
      0% { transform: scale(0.5); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }
  </style>
</head>
<body>

<header>
  <strong>Dimitri Krokos</strong>
  <nav>
    <a href="#about">À propos</a>
    <a href="#services">Services</a>
    <a href="#rdv">Rendez-vous</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<div class="hero">
  <div>
    <h1>Psychologue & Neuropsychologue</h1>
    <p>Un accompagnement moderne, scientifique et profondément humain, dans un cadre professionnel et confidentiel.</p>
    <a class="btn" href="#rdv">Prendre rendez-vous</a>
  </div>
  <img src="photo.jpg" alt="Dimitri Krokos">
</div>

<section id="about">
  <h2>À propos</h2>
  <p>Dimitri Krokos accompagne enfants, adolescents et adultes avec une approche rigoureuse, bienveillante et personnalisée.</p>
</section>

<section id="services">
  <h2>Services</h2>
  <div class="cards">
    <div class="card">Consultations psychologiques individuelles</div>
    <div class="card">Bilans et évaluations neuropsychologiques</div>
    <div class="card">Suivi enfants, adolescents et adultes</div>
  </div>
</section>

<section id="rdv">
  <h2>Prise de rendez-vous</h2>
  <form id="rdvForm">
    <input type="text" name="name" placeholder="Nom complet" required>
    <input type="email" name="email" placeholder="Adresse email" required>
    <input type="date" name="date" required>
    <select name="type">
      <option>Consultation</option>
      <option>Bilan neuropsychologique</option>
    </select>
    <button class="btn" type="submit">Réserver</button>
    <p id="rdvStatus" style="color:#7dd3fc"></p>
  </form>
</section>

<section id="contact">
  <h2>Contact</h2>
  <form>
    <input type="text" placeholder="Nom">
    <input type="email" placeholder="Email">
    <textarea rows="4" placeholder="Message"></textarea>
    <button class="btn">Envoyer</button>
  </form>
  <iframe src="https://www.google.com/maps?q=Bruxelles&output=embed"></iframe>
</section>

<footer>
  © 2026 – Dimitri Krokos · Site professionnel
</footer>

<script src="https://cdn.jsdelivr.net/npm/emailjs-com@3/dist/email.min.js"></script>

<script>
(function () {
  emailjs.init("KaRPZffOesNTUxaXw");
})();

// ===== Multi-langue =====
const LANG = {
  fr: { sending: "Envoi en cours…", success: "Rendez-vous confirmé ✔", error: "Erreur lors de l’envoi ❌", wait: "Veuillez patienter quelques secondes." },
  en: { sending: "Sending…", success: "Appointment confirmed ✔", error: "Sending error ❌", wait: "Please wait a few seconds." },
  nl: { sending: "Verzenden…", success: "Afspraak bevestigd ✔", error: "Verzendfout ❌", wait: "Even geduld alstublieft." }
};

const userLang = navigator.language.startsWith("nl") ? "nl" : navigator.language.startsWith("en") ? "en" : "fr";

// ===== Variables =====
const form = document.getElementById("rdvForm");
const statusText = document.getElementById("rdvStatus");
const dateInput = form.querySelector("input[type='date']");
let sending = false;
const formLoadedAt = Date.now();

// ===== Calendrier intelligent =====
const today = new Date().toISOString().split("T")[0];
dateInput.setAttribute("min", today);

dateInput.addEventListener("change", () => {
  const selected = new Date(dateInput.value);
  const day = selected.getDay(); // 0 = dim, 6 = sam
  if (day === 0 || day === 6) {
    dateInput.value = "";
    statusText.textContent = "Les week-ends ne sont pas disponibles.";
  }
});

// ===== Animation succès =====
function successAnimation() {
  statusText.innerHTML = "✔";
  statusText.style.fontSize = "32px";
  statusText.style.color = "#38bdf8";
  statusText.style.textShadow = "0 0 20px #38bdf8";
  statusText.style.animation = "pop 0.6s ease";
}

// ===== Envoi formulaire =====
form.addEventListener("submit", function (e) {
  e.preventDefault();
  if (sending) return;
  if (Date.now() - formLoadedAt < 3000) { statusText.textContent = LANG[userLang].wait; return; }

  sending = true;
  statusText.textContent = LANG[userLang].sending;

  const data = {
    name: form.name.value,
    email: form.email.value,
    date: form.date.value,
    type: form.type.value,
    to_email: "yannikrokos939@gmail.com"
  };

  emailjs.send("service_mpyrlzu", "template_n1eub9f", data)
    .then(() => {
      successAnimation();
      setTimeout(() => { statusText.textContent = LANG[userLang].success; }, 700);
      form.reset();
      sending = false;

      // Confirmation client
      emailjs.send("service_mpyrlzu", "template_n1eub9f", { ...data, confirmation: "Votre demande de rendez-vous a bien été reçue." });
    })
    .catch(() => {
      statusText.textContent = LANG[userLang].error;
      sending = false;
    });
});
</script>
</body>
</html>

